# Recommended security/cache headers for the Response Option Fit Lab static build.
# Cloudflare Pages and Netlify both honor this `_headers` file at the site root.
# For other hosts, mirror these into the host's header configuration.
#
# NOTE: on the live site (benlei.org/response-option-fit/) the mount Worker sets
# the security headers itself and overrides these. This file therefore governs
# only the Pages origin (response-option-fit.pages.dev) and other hosts. The
# Cloudflare Web Analytics beacon is injected by the Worker on the mounted path
# only, so the analytics CSP allowance lives in the Worker, not here.

/*
  Content-Security-Policy: default-src 'none'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; form-action 'none'; base-uri 'self'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cache-Control: public, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
