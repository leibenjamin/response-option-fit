# Supply-chain guard: never run dependency lifecycle scripts on install.
# The 2025-2026 npm worms (Shai-Hulud, Miasma, the node-gyp/binding.gyp
# compromise) all spread through install hooks. This tree needs none on
# Linux or CI — the only packages that declare them are the macOS-only
# fsevents — so the guard costs nothing here. If a future dependency
# legitimately needs an install script, the breakage is loud and the script
# can be reviewed and run deliberately instead of implicitly.
ignore-scripts=true
